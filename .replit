modules = ["python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo '⚠️  Replit é só pra editar/analisar código. NÃO compila e NÃO roda o jogo.' && echo '   O build (5626 arquivos) é feito no PC do Agente Cris via bash build.sh / rebuild_runtime.sh.' && echo '   Veja replit.md → seção \"Regras pro agente Replit\" (linha ~1138).'"
